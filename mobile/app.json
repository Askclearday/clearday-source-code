{
  "expo": {
    "name": "Clearday",
    "slug": "luna",
    "version": "1.4.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lunascroll",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lunascroll.app",
      "buildNumber": "57",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Clearday uses the microphone so you can speak notes, reminders, and calendar entries instead of typing them.",
        "NSLocationWhenInUseUsageDescription": "Clearday uses your location to include your city and local weather in your daily brief.",
        "NSUserNotificationUsageDescription": "Clearday sends scheduled notifications to deliver your daily brief and reminders at the right time."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000"
      },
      "package": "com.lunascroll.app",
      "versionCode": 57,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router"
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#E8915C",
          "defaultChannel": "clearday",
          "sounds": ["./assets/sounds/notification.wav"]
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Clearday uses your location to include your city and local weather in your daily brief."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Clearday uses the microphone so you can speak notes, reminders, and calendar entries."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c0020f9e-1566-486e-b714-ce59fc73681f"
      }
    }
  }
}
